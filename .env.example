# ---- Copy to .env and fill in. NEVER commit the real .env ----

# MongoDB Atlas connection string (free tier works fine)
# e.g. mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/portfolio?retryWrites=true&w=majority
MONGODB_URI=

# Port the server listens on (Render sets this automatically)
PORT=3000

# ---- Admin auth (used ONLY by `npm run seed`) ----
# These seed the admin account. After seeding you can delete them from the env if you like.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Secret used to sign login session tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# ---- The hidden admin route ----
# The admin panel lives at /<ADMIN_ROUTE>. Pick an unguessable word. No leading slash.
# Anyone who doesn't know this exact slug just gets the normal 404 page.
ADMIN_ROUTE=studio-7f3a91

# Set to "production" on Render so cookies are marked Secure.
NODE_ENV=development
